          },
          "http": {
            "method": "POST",
            "url": "https://api.dsco.io/api/v3/supplier/catalog-in",
            "body": {
              "type": "json",
              "data": "{}"
            },
            "auth": {
              "type": "bearer",
              "token": "{{bearerToken}}"
            }
          },
          "docs": "Supplier operation to create or update product catalog items. Supports small batch (synchronous) and large batch (asynchronous) modes."
        },
        {
          "info": {
            "name": "Update Catalog Attribution",
            "type": "http"
