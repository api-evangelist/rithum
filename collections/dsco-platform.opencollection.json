              "type": "json",
              "data": "{}"
            },
            "auth": {
              "type": "bearer",
              "token": "{{bearerToken}}"
            }
          },
          "docs": "Create a new event stream with query parameters for filtering events. Streams enable near-real-time event delivery via micro-polling."
